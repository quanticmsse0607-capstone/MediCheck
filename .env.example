# MediCheck — Required Environment Variables
# Copy this file to .env and fill in all values before running any service locally.
# Never commit .env to the repository.

# ── AWS Textract (Service 2) ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# ── OpenAI (Service 3) ───────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── ChromaDB (Service 3) ─────────────────────────────────────────────────────
# Disables ChromaDB anonymous usage telemetry
ANONYMIZED_TELEMETRY=False

# ── PostgreSQL (Service 2) ───────────────────────────────────────────────────
DATABASE_URL=

# ── Inter-service communication ──────────────────────────────────────────────
# URL of the deployed RAG & Letter Service (Service 3)
RAG_SERVICE_URL=

# ── Render deploy hooks (CI/CD pipeline only) ────────────────────────────────
RENDER_DEPLOY_HOOK_FRONTEND=
RENDER_DEPLOY_HOOK_BILL_ANALYSIS=
RENDER_DEPLOY_HOOK_RAG_SERVICE=

# ── Flask (Services 2 and 3) ─────────────────────────────────────────────────
# For session signing and CSRF protection
FLASK_SECRET_KEY=
FLASK_ENV=development
# MediCheck — Service 1: Frontend
# Copy to .env.local and fill in values before running locally.
# Never commit .env.local to the repository.

# URL of Service 2 (Bill Analysis API)
# In local development this is proxied via vite.config.js — leave blank to use proxy
# In production (Render) set this to the full Service 2 URL
VITE_API_BASE_URL=

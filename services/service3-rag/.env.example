# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ChromaDB — path where the vector store is persisted
CHROMA_PERSIST_PATH=./data/chroma_db

# CORS — comma-separated list of allowed origins
# Set to the Render URL of Service 2 in production
CORS_ORIGINS=http://localhost:5000

# Service 2 URL (if Service 3 needs to call back)
SERVICE2_URL=http://localhost:5000

# Flask
FLASK_ENV=development
SECRET_KEY=pick-any-random-string-here
